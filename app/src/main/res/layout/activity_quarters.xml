<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Quarters"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap crew to select, then move them"
        android:textSize="14sp"
        android:layout_marginBottom="12dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerCrew"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <Button
        android:id="@+id/btnToSimulator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Move to Simulator"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/btnToMissionControl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Move to Mission Control"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/btnToCasino"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Move to Casino"
        android:layout_marginTop="8dp" />

</LinearLayout>